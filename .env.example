TG_API_ID=
TG_API_HASH=

# Required: pre-generated Telethon StringSession
TG_STRING_SESSION=

# Base display name
BASE_NAME=your-name

# Timezone
TZ_NAME=China/Shanghai

# Update interval (recommended >= 60; too frequent may trigger FloodWait)
INTERVAL_SECONDS=60

# Suffix format (default: {time})
SUFFIX_FORMAT={time}

# Poll interval (default: 1s). It checks every second, not rename every second.
POLL_SECONDS=1

# Advance to next minute by this offset
AHEAD_SECONDS=0

# Scheduling guard buffer (0.1~0.5 is usually fine)
GUARD_SECONDS=0.2

# Weather switch and location (default: Shanghai)
WEATHER_ENABLED=1

# Weather refresh interval (default: 1800s = 30 minutes)
WEATHER_REFRESH_SECONDS=900

# ✅ Your dedicated API host from QWeather console (without https://)
QW_HOST=your-host.re.qweatherapi.com

# ✅ Location: lon,lat (order matters) or LocationID
QW_LOCATION=121.47,31.23

# ✅ Dynamic JWT (recommended)
QW_PROJECT_ID=
QW_KEY_ID=
QW_PRIVATE_KEY=
QW_JWT_TTL_SECONDS=900

# Optional: static JWT or API key (choose one; usually left empty)
QW_JWT=
# QW_API_KEY=

# Optional
QW_LANG=en
QW_UNIT=m

WEATHER_REFRESH_SECONDS=1800
WEATHER_ENABLED=1
