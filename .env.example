TG_API_ID=
TG_API_HASH=

# Required: pre-generated Telethon StringSession
TG_STRING_SESSION=

# Base display name
BASE_NAME=your-name

# Timezone
TZ_NAME=China/Shanghai

# Time template. {time} is replaced with HH:MM.
TIME_FORMAT={time}

# Unicode style for time and temperature: normal, bold/fancy, italic, bold_italic, script, bold_script, fraktur, bold_fraktur, double_struck, sans, sans_italic, sans_bold, sans_bold_italic, monospace
# Hyphen/space variants are accepted, e.g. sans-serif-bold or "sans serif bold".
# Styles without digit glyphs keep digits plain; fancy is kept as a bold alias for backward compatibility.
TIME_STYLE=fancy
TEMP_STYLE=fancy

# Advance to next minute by this offset
AHEAD_SECONDS=0

# Scheduling guard buffer (0.1~0.5 is usually fine)
GUARD_SECONDS=0.2

# Weather switch
WEATHER_ENABLED=1

# Weather refresh interval (default: 1800s = 30 minutes)
WEATHER_REFRESH_SECONDS=1800

# QWeather is used first when auth is configured.
# Leave QWeather credentials empty to use the free, no-registration Open-Meteo fallback.

# Your dedicated API host from QWeather console (without https://)
QW_HOST=your-host.re.qweatherapi.com

# Location: lon,lat (order matters) or QWeather LocationID.
# Open-Meteo fallback can reuse this only when it is lon,lat.
QW_LOCATION=121.47,31.23

# Dynamic JWT (recommended)
QW_PROJECT_ID=
QW_KEY_ID=
QW_PRIVATE_KEY=
QW_JWT_TTL_SECONDS=900

# Optional: static JWT or API key (choose one; usually left empty)
QW_JWT=
# QW_API_KEY=

# Optional: Open-Meteo fallback coordinates.
# Use these if QW_LOCATION is a QWeather LocationID, or to keep fallback config separate.
OPEN_METEO_LATITUDE=
OPEN_METEO_LONGITUDE=

# Optional
QW_LANG=en
QW_UNIT=m
